# --- admin ---
# URL бэкенда для сборки фронтенда admin
# Локально: http://localhost:4001  |  На сервере: https://admin-api.example.com
VITE_API_URL=http://localhost:4001

# --- miniapp ---
# URL API miniapp-backend
MINIAPP_API_URL=http://localhost:4002
# chat id менеджера (telegram user id) для кнопки «Поддержка» (например 123456789)
VITE_SUPPORT_TG_ID=123456789
# допустимые origins для CORS в miniapp-backend (через запятую)
MINIAPP_ALLOWED_ORIGINS=http://localhost:5173

# --- bot ---
BOT_TOKEN=
# публичный https URL фронтенда мини-аппа (Telegram требует https)
MINIAPP_URL=https://miniapp.example.com

# --- уведомления о заказах в telegram-канал ---
# ID канала или группы куда бот отправляет новые заказы (например -1001234567890)
ORDERS_CHANNEL_ID=-1003660164829
# секрет для internal endpoint admin-backend (бот → admin-backend без сессионной авторизации)
BOT_INTERNAL_SECRET=
# URL admin-backend изнутри docker-сети (для бота, чтобы менять статусы)
# по умолчанию: http://nikotinich-admin-backend:4001
ADMIN_BACKEND_URL=http://nikotinich-admin-backend:4001

# --- общее ---
GOOGLE_SHEET_ID=10a5oZw...
APP_VERSION=0.1.0
