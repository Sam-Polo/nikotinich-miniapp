PORT=4001
JWT_SECRET=
GOOGLE_SHEET_ID=
GOOGLE_SA_FILE=./sa.json
SHEET_NAMES=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
ADMIN_FRONTEND_URL=http://localhost:5174
ADMIN_IMPORT_KEY=
BACKEND_URL=
LOG_LEVEL=info
NODE_ENV=development

# media storage
MEDIA_PROVIDER=s3
MEDIA_OBJECT_PREFIX=dev/products
APP_VERSION=0.1.0-local

# s3 public/private buckets
S3_ENDPOINT=https://s3.regru.cloud
S3_REGION=ru-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BUCKET=
S3_PRIVATE_BUCKET=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=true

# local media fallback
MEDIA_LOCAL_DIR=uploads
MEDIA_LOCAL_PUBLIC_BASE_URL=http://localhost:4001/uploads

# image optimization
IMAGE_MAX_WIDTH=1600
IMAGE_WEBP_QUALITY=82
